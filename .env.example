# Supabase — dados do projeto (Project Settings → API)
# URL do projeto, ex.: https://xxxxxxxx.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Chave pública (anon) — usada no client da sessão (respeita RLS)
SUPABASE_ANON_KEY=<anon-key>

# Chave service_role — SECRETA, só server-side. Gerencia usuários do Auth.
# Nunca exponha no client nem use prefixo PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
