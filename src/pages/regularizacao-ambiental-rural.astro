---
export const prerender = false;
// src/pages/regularizacao-ambiental-rural.astro
// LP — Regularização Ambiental de Imóvel Rural | Nemes & Teibel Advogados
// Tráfego: Google Ads (noindex via LPLayout) — CTA único: WhatsApp
// ⚠️ Conteúdo baseado em transcrição simulada — confirmar com Dra. Paula Teibel antes de publicar
import LPLayout from '../layouts/LPLayout.astro';

const WA = 'https://wa.me/556541410010?text=Vim%20pelo%20site!%20Quero%20entender%20a%20situa%C3%A7%C3%A3o%20ambiental%20da%20minha%20propriedade.';

const problems = [
  {
    title: 'CAR desatualizado ou mal feito',
    text: 'Cadastro feito sem acompanhamento técnico, com reserva legal mal delimitada ou área que não bate com a matrícula. Gera pendência que trava crédito rural, venda e financiamento.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75" />
    </svg>`,
    delay: 'reveal-d1',
  },
  {
    title: 'Embargo do IBAMA ou da SEMA',
    text: 'Tem produtor que comprou terra já embargada sem saber. Enquanto o embargo não é levantado, a área fica com a mão atada — sem uso, sem crédito, sem saída.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
    </svg>`,
    delay: 'reveal-d2',
  },
  {
    title: 'Reserva legal que existe mas não está reconhecida',
    text: 'A mata está lá, mas não está averbada na matrícula nem georreferenciada. Parece detalhe — mas impede uma série de coisas na prática.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 3.03v.568c0 .334.148.65.405.864l1.068.89c.442.369.535 1.01.216 1.49l-.51.766a2.25 2.25 0 01-1.161.886l-.143.048a1.107 1.107 0 00-.57 1.664c.369.555.169 1.307-.427 1.605L9 13.125l.423 1.059a.956.956 0 01-1.652.928l-.679-.906a1.125 1.125 0 00-1.906.172L4.5 15.75l-.612.153M12.75 3.031a9 9 0 00-8.862 12.872M12.75 3.031a9 9 0 016.69 14.036m0 0l-.177-.529A2.249 2.249 0 0017.128 15H16.5l-.324-.324a1.453 1.453 0 00-2.328.377l-.036.073a1.586 1.586 0 01-.982.816l-.99.282c-.55.157-.894.702-.8 1.267l.073.438c.08.474.49.821.97.821.846 0 1.598.542 1.865 1.345l.215.643" />
    </svg>`,
    delay: 'reveal-d3',
  },
];
---

<LPLayout
  title="Regularização Ambiental Rural em MT | Nemes & Teibel Advogados"
  description="CAR irregular, embargo ou reserva legal não averbada em MT? Resolva seu passivo ambiental com especialistas em Direito Ambiental Rural. Fale agora."
>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCOS 01 + 02 + 03 — Hero                                     -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-hero" aria-label="Regularização Ambiental Rural — apresentação">

    <img
      class="lp-hero-bg"
      src="/img/bg1.avif"
      alt=""
      aria-hidden="true"
      width="1920"
      height="1000"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="lp-hero-overlay" aria-hidden="true"></div>

    <div class="lp-hero-content">
      <img
        src="/img/logo.avif"
        alt="Nemes &amp; Teibel Advogados"
        class="lp-hero-logo reveal"
        width="180"
        height="50"
        decoding="async"
      />
      <h1 class="lp-hero-h1 reveal reveal-d1">
        Regularização Ambiental Rural em MT: resolva o passivo antes que trave tudo
      </h1>
      <p class="lp-hero-sub reveal reveal-d2">
        CAR irregular, embargo ou reserva legal não averbada? Seu imóvel pode estar impedindo venda, crédito rural e transferência sem você saber.
      </p>
      <p class="lp-hero-support reveal reveal-d3">
        Fale agora com uma especialista em Regularização Ambiental em Mato Grosso
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green lp-hero-cta reveal reveal-d4"
        aria-label="Quero regularizar minha situação ambiental — WhatsApp"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Quero regularizar minha situação ambiental
      </a>
    </div>

  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 04 — Credenciais em destaque                             -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-creds" aria-label="Credenciais da especialista">
    <div class="lp-creds-inner">

      <div class="lp-cred reveal reveal-d1">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>Ex-servidora do INTERMAT — conhece os órgãos ambientais de MT por dentro</span>
      </div>

      <div class="lp-cred-divider" aria-hidden="true"></div>

      <div class="lp-cred reveal reveal-d2">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>+20 anos em Direito Agrário, Fundiário e Ambiental</span>
      </div>

      <div class="lp-cred-divider" aria-hidden="true"></div>

      <div class="lp-cred reveal reveal-d3">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>Especialização em Direito Minerário e Ambiental — PUC Minas</span>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 05 — Problemas que Resolvemos                            -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-problems" aria-labelledby="lp-problems-heading">
    <div class="container">

      <header class="lp-section-header">
        <h2 id="lp-problems-heading" class="section-title reveal">
          Seu imóvel tem algum desses problemas?
        </h2>
      </header>

      <div class="lp-problems-grid">
        {problems.map((p) => (
          <article class={`lp-problem-card reveal ${p.delay}`}>
            <div class="lp-problem-icon" set:html={p.icon} />
            <h3 class="lp-problem-title">{p.title}</h3>
            <p class="lp-problem-text">{p.text}</p>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 06 — Prova Social                                        -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-social" aria-label="Caso real e resultados">
    <div class="lp-social-inner">

      <!-- Coluna esquerda: frase de impacto -->
      <div class="lp-social-text">

        <div class="lp-social-badge reveal">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Caso real
        </div>

        <blockquote class="lp-impact reveal reveal-d1">
          <span class="lp-impact-quotes" aria-hidden="true">"</span>
          Passivo ambiental não some com o tempo — ele cresce.
        </blockquote>

        <p class="lp-social-sub reveal reveal-d2">
          Multa sobre multa, restrição sobre restrição. Quanto antes você entender o que está irregular, mais fácil e mais barato fica de resolver.
        </p>

        <div class="lp-social-stats reveal reveal-d3" aria-label="Números do escritório">
          <div class="lp-stat">
            <span class="lp-stat-num">20+</span>
            <span class="lp-stat-label">anos em Direito Ambiental</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">MT</span>
            <span class="lp-stat-label">IBAMA e SEMA</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">100%</span>
            <span class="lp-stat-label">foco no campo</span>
          </div>
        </div>

      </div>

      <!-- Coluna direita: card de caso concreto -->
      <div class="lp-case-wrap reveal reveal-d2">
        <div class="lp-case-card">

          <div class="lp-case-header">
            <div class="lp-case-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
              </svg>
            </div>
            <span class="lp-case-tag">Resolução de embargo</span>
          </div>

          <p class="lp-case-story">
            Uma fazenda com dois embargos ativos do IBAMA cobrindo quase 30% da área — o produtor não sabia que existiam.
          </p>

          <div class="lp-case-numbers">
            <div class="lp-case-num">
              <span class="lp-case-num-val">2</span>
              <span class="lp-case-num-label">embargos IBAMA</span>
            </div>
            <div class="lp-case-num">
              <span class="lp-case-num-val">30%</span>
              <span class="lp-case-num-label">da área embargada</span>
            </div>
          </div>

          <div class="lp-case-outcome">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            <span>Embargos resolvidos. Crédito rural liberado.</span>
          </div>

          <p class="lp-case-disclaimer">
            ⚠️ Caso a confirmar com a Dra. Paula Teibel antes da publicação.
          </p>

        </div>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 07 — Quem vai te atender                                 -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-expert" aria-label="Sobre a advogada especialista">
    <div class="container lp-expert-inner">

      <div class="lp-expert-photo-wrap reveal">
        <!-- Substituir pelo <img src="/img/paula-teibel.webp" ... /> quando a foto estiver disponível -->
        <div class="lp-expert-photo-placeholder" aria-label="Foto de Paula Teibel — a inserir">
          <span class="lp-expert-initials" aria-hidden="true">PT</span>
          <p class="lp-expert-photo-hint">Foto a inserir</p>
        </div>
      </div>

      <div class="lp-expert-bio reveal reveal-d1">
        <p class="lp-expert-label">Quem vai te atender</p>
        <h2 class="lp-expert-name">Paula Teibel</h2>
        <p class="lp-expert-role">Especialista em Direito Ambiental e Fundiário em Mato Grosso</p>
        <p class="lp-expert-text">
          Paula tem mais de 20 anos de atuação em Direito Agrário, Fundiário e Ambiental. Foi servidora do INTERMAT — o Instituto de Terras do Estado de Mato Grosso — e tem especialização em Direito Minerário e Ambiental pela PUC Minas. Ela conhece o funcionamento dos órgãos ambientais do estado, sabe como negociar embargos na esfera administrativa e quando é necessário ir à via judicial. O que não faz é deixar o passivo acumular.
        </p>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-green"
          aria-label="Falar com Paula Teibel pelo WhatsApp"
        >
          <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
          </svg>
          Falar com Paula Teibel
        </a>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 08 — CTA Final                                           -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-cta-final" aria-label="Convite final para contato">
    <div class="container lp-cta-final-inner reveal">
      <p class="lp-cta-context">
        Passivo ambiental não some com o tempo — ele cresce. Multa sobre multa, restrição sobre restrição. Quanto antes você entender o que está irregular, mais fácil e mais barato fica de resolver.
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green lp-cta-final-btn"
        aria-label="Entender a situação ambiental da minha propriedade — WhatsApp"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Entender a situação ambiental da minha propriedade
      </a>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- RODAPÉ LEGAL                                                    -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <footer class="lp-footer" aria-label="Rodapé com informações legais">
    <div class="container lp-footer-inner">
      <img
        src="/img/logo.avif"
        alt="Nemes &amp; Teibel Advogados"
        class="lp-footer-logo"
        width="140"
        height="40"
        loading="lazy"
        decoding="async"
      />
      <p class="lp-footer-legal">
        Este site não representa captação de clientela ou oferta de serviços advocatícios, conforme o Código de Ética e Disciplina da OAB.
      </p>
      <p class="lp-footer-info">
        Nemes &amp; Teibel Advogados — OAB/MT | CNPJ: 32.181.460/0001-50 | Cuiabá, Mato Grosso
      </p>
    </div>
  </footer>

</LPLayout>

<style>
  /* ── WA icon ─────────────────────────────────────── */
  .wa-icon { width: 20px; height: 20px; flex-shrink: 0; }

  /* ── HERO ────────────────────────────────────────── */
  .lp-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .lp-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .lp-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      150deg,
      rgba(6, 18, 6, 0.93) 0%,
      rgba(10, 28, 10, 0.83) 55%,
      rgba(20, 40, 16, 0.75) 100%
    );
    z-index: 1;
  }
  .lp-hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
    padding: 5rem var(--padding-x);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lp-hero-logo {
    height: 64px;
    width: auto;
    margin-bottom: 2.5rem;
  }
  .lp-hero-h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.85rem, 4.6vw, 3.3rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .lp-hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
    max-width: 640px;
    margin-bottom: 1.25rem;
  }
  .lp-hero-support {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-gold);
    font-weight: 600;
    margin-bottom: 2.25rem;
  }
  .lp-hero-cta { font-size: 1.05rem; padding: 1.05rem 2.25rem; }

  /* ── CREDENCIAIS ─────────────────────────────────── */
  .lp-creds {
    background: #2A2316;
    padding: 2.75rem var(--padding-x);
    border-top: 1px solid rgba(184, 151, 42, 0.2);
  }
  .lp-creds-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lp-cred {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    flex: 1;
    min-width: 220px;
    max-width: 340px;
    padding: 1rem 2rem;
  }
  .lp-cred-check { color: var(--color-accent); font-size: 1.1rem; flex-shrink: 0; margin-top: 0.15rem; }
  .lp-cred span:last-child { color: rgba(255, 255, 255, 0.88); font-size: 0.9rem; line-height: 1.55; font-weight: 500; }
  .lp-cred-divider { width: 1px; background: rgba(184, 151, 42, 0.2); align-self: stretch; flex-shrink: 0; }

  /* ── PROBLEMAS ───────────────────────────────────── */
  .lp-problems {
    background: var(--color-bg);
    padding: clamp(4rem, 7vw, 6rem) var(--padding-x);
  }
