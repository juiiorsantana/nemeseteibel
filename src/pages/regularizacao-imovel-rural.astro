---
export const prerender = false;
// src/pages/regularizacao-imovel-rural.astro
// LP — Regularização de Imóvel Rural | Nemes & Teibel Advogados
// Tráfego: Google Ads (noindex via LPLayout) — CTA único: WhatsApp
import LPLayout from '../layouts/LPLayout.astro';

const WA = 'https://wa.me/556541410010?text=Vim%20pelo%20site!%20Quero%20regularizar%20minha%20propriedade%20rural.';

const problems = [
  {
    title: 'Imóvel sem documento ou com documentação incompleta',
    text: 'Propriedade sem matrícula, com registro desatualizado ou que não bate com a área real. Isso trava venda, financiamento e inventário.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
    </svg>`,
    delay: 'reveal-d1',
  },
  {
    title: 'Sobreposição de áreas e conflito de limites',
    text: 'Dois registros cobrindo a mesma terra, ou divisa que não corresponde ao que está cercado. Situação comum em MT — que só o estudo técnico jurídico revela com clareza.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
    </svg>`,
    delay: 'reveal-d2',
  },
  {
    title: 'Embargos e multas ambientais que travam o imóvel',
    text: 'Passivo ambiental não resolvido impede venda, crédito rural e transferência. A gente mapeia o que existe e aponta o caminho para regularizar.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
    </svg>`,
    delay: 'reveal-d3',
  },
];
---

<LPLayout
  title="Regularização de Imóvel Rural em MT | Nemes & Teibel Advogados"
  description="Regularize seu imóvel rural em Mato Grosso com segurança jurídica. Especialistas em Direito Fundiário e ex-servidora do INTERMAT. Fale agora."
>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCOS 01 + 02 + 03 — Hero                                     -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-hero" aria-label="Regularização de Imóvel Rural — apresentação">

    <img
      class="lp-hero-bg"
      src="/img/bgsecao2.avif"
      alt=""
      aria-hidden="true"
      width="1920"
      height="1000"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="lp-hero-overlay" aria-hidden="true"></div>

    <div class="lp-hero-content">
      <img
        src="/img/logo.avif"
        alt="Nemes &amp; Teibel Advogados"
        class="lp-hero-logo reveal"
        width="180"
        height="50"
        decoding="async"
      />
      <h1 class="lp-hero-h1 reveal reveal-d1">
        Regularização de Imóvel Rural em MT com Segurança Jurídica Total
      </h1>
      <p class="lp-hero-sub reveal reveal-d2">
        Sua propriedade regularizada, documentação em ordem e patrimônio protegido — sem surpresas no processo.
      </p>
      <p class="lp-hero-support reveal reveal-d3">
        Fale agora com uma especialista em Regularização Fundiária em Mato Grosso
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green lp-hero-cta reveal reveal-d4"
        aria-label="Quero regularizar minha propriedade — WhatsApp"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Quero regularizar minha propriedade
      </a>
    </div>

  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 04 — Credenciais em destaque                             -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-creds" aria-label="Credenciais da especialista">
    <div class="lp-creds-inner">

      <div class="lp-cred reveal reveal-d1">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>Ex-servidora do INTERMAT — conhece o processo por dentro</span>
      </div>

      <div class="lp-cred-divider" aria-hidden="true"></div>

      <div class="lp-cred reveal reveal-d2">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>+20 anos em Direito Agrário, Fundiário e Ambiental em MT</span>
      </div>

      <div class="lp-cred-divider" aria-hidden="true"></div>

      <div class="lp-cred reveal reveal-d3">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>Integração jurídica e técnica em um único estudo completo</span>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 05 — Problemas que Resolvemos                            -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-problems" aria-labelledby="lp-problems-heading">
    <div class="container">

      <header class="lp-section-header">
        <h2 id="lp-problems-heading" class="section-title reveal">
          Sua propriedade tem algum desses problemas?
        </h2>
      </header>

      <div class="lp-problems-grid">
        {problems.map((p) => (
          <article class={`lp-problem-card reveal ${p.delay}`}>
            <div class="lp-problem-icon" set:html={p.icon} />
            <h3 class="lp-problem-title">{p.title}</h3>
            <p class="lp-problem-text">{p.text}</p>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 06 — Prova Social                                        -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-social" aria-label="Resultados e depoimentos">
    <div class="lp-social-inner">

      <!-- Coluna esquerda: impacto + stats -->
      <div class="lp-social-text">

        <div class="lp-social-badge reveal">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Resultados reais
        </div>

        <blockquote class="lp-impact reveal reveal-d1">
          <span class="lp-impact-quotes" aria-hidden="true">"</span>
          Dezenas de propriedades rurais regularizadas em Mato Grosso.
        </blockquote>

        <p class="lp-social-sub reveal reveal-d2">
          Cada caso analisado de forma completa — documentação, limites, registros e questões ambientais. Do estudo técnico jurídico à regularização definitiva.
        </p>

        <div class="lp-social-stats reveal reveal-d3" aria-label="Números do escritório">
          <div class="lp-stat">
            <span class="lp-stat-num">20+</span>
            <span class="lp-stat-label">anos em Direito Fundiário</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">MT</span>
            <span class="lp-stat-label">e Centro-Oeste</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">100%</span>
            <span class="lp-stat-label">foco no campo</span>
          </div>
        </div>

      </div>

      <!-- Coluna direita: depoimento -->
      <div class="lp-testimonial-wrap reveal reveal-d2">
        <div class="lp-testimonial">
          <svg class="lp-testimonial-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <p class="lp-testimonial-text">
            "Minha propriedade estava [situação irregular]. Com a Nemes &amp; Teibel, consegui [resultado concreto — vender, financiar, regularizar a herança]."
          </p>
          <div class="lp-testimonial-author">
            <div class="lp-testimonial-avatar" aria-hidden="true"></div>
            <div>
              <p class="lp-testimonial-name">Nome do cliente</p>
              <p class="lp-testimonial-city">Cidade, MT — situação resolvida</p>
            </div>
          </div>
          <p class="lp-testimonial-pending">⟳ Aguardando depoimento real do escritório</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 07 — Quem vai te atender                                 -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-expert" aria-label="Sobre a advogada especialista">
    <div class="container lp-expert-inner">

      <div class="lp-expert-photo-wrap reveal">
        <!-- Substituir pelo <img src="/img/paula-teibel.webp" ... /> quando a foto estiver disponível -->
        <div class="lp-expert-photo-placeholder" aria-label="Foto de Paula Teibel — a inserir">
          <span class="lp-expert-initials" aria-hidden="true">PT</span>
          <p class="lp-expert-photo-hint">Foto a inserir</p>
        </div>
      </div>

      <div class="lp-expert-bio reveal reveal-d1">
        <p class="lp-expert-label">Quem vai te atender</p>
        <h2 class="lp-expert-name">Paula Teibel</h2>
        <p class="lp-expert-role">Especialista em Regularização Fundiária em Mato Grosso</p>
        <p class="lp-expert-text">
          Paula tem mais de 20 anos de atuação em Direito Agrário, Fundiário e Ambiental. Antes de advogar, trabalhou no INTERMAT — o Instituto de Terras do Estado de Mato Grosso, que é exatamente o órgão responsável pela regularização fundiária no estado. Ela não só conhece a legislação: conhece o processo por dentro, sabe como os órgãos funcionam e o que é preciso para chegar na regularização de verdade.
        </p>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-green"
          aria-label="Falar com Paula Teibel pelo WhatsApp"
        >
          <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
          </svg>
          Falar com Paula Teibel
        </a>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 08 — CTA Final                                           -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-cta-final" aria-label="Convite final para contato">
    <div class="container lp-cta-final-inner reveal">
      <p class="lp-cta-context">
        Cada propriedade tem uma situação diferente. O primeiro passo é entender o que precisa ser resolvido no seu caso — antes que vire um problema maior.
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green lp-cta-final-btn"
        aria-label="Falar com especialista agora — WhatsApp"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Falar com especialista agora
      </a>
    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- RODAPÉ LEGAL                                                    -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <footer class="lp-footer" aria-label="Rodapé com informações legais">
    <div class="container lp-footer-inner">
      <img
        src="/img/logo.avif"
        alt="Nemes &amp; Teibel Advogados"
        class="lp-footer-logo"
        width="140"
        height="40"
        loading="lazy"
        decoding="async"
      />
      <p class="lp-footer-legal">
        Este site não representa captação de clientela ou oferta de serviços advocatícios, conforme o Código de Ética e Disciplina da OAB.
      </p>
      <p class="lp-footer-info">
        Nemes &amp; Teibel Advogados — OAB/MT | CNPJ: 32.181.460/0001-50 | Cuiabá, Mato Grosso
      </p>
    </div>
  </footer>

</LPLayout>

<style>
  /* ── WA icon ─────────────────────────────────────── */
  .wa-icon { width: 20px; height: 20px; flex-shrink: 0; }

  /* ── HERO ────────────────────────────────────────── */
  .lp-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .lp-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .lp-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      150deg,
      rgba(14, 20, 8, 0.92) 0%,
      rgba(22, 32, 12, 0.80) 60%,
      rgba(38, 52, 20, 0.72) 100%
    );
    z-index: 1;
  }
  .lp-hero-content {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
    padding: 5rem var(--padding-x);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lp-hero-logo {
    height: 64px;
    width: auto;
    margin-bottom: 2.5rem;
  }
  .lp-hero-h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.9rem, 4.8vw, 3.4rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1.5rem;
  }
  .lp-hero-sub {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.7;
    max-width: 620px;
    margin-bottom: 1.25rem;
  }
  .lp-hero-support {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-gold);
    font-weight: 600;
    margin-bottom: 2.25rem;
  }
  .lp-hero-cta {
    font-size: 1.05rem;
    padding: 1.05rem 2.25rem;
  }

  /* ── CREDENCIAIS ─────────────────────────────────── */
  .lp-creds {
    background: #2A2316;
    padding: 2.75rem var(--padding-x);
    border-top: 1px solid rgba(184, 151, 42, 0.2);
  }
  .lp-creds-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lp-cred {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    flex: 1;
    min-width: 220px;
    max-width: 340px;
    padding: 1rem 2rem;
  }
  .lp-cred-check {
    color: var(--color-accent);
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .lp-cred span:last-child {
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.9rem;
    line-height: 1.55;
    font-weight: 500;
  }
  .lp-cred-divider {
    width: 1px;
    background: rgba(184, 151, 42, 0.2);
    align-self: stretch;
    flex-shrink: 0;
  }

  /* ── PROBLEMAS ───────────────────────────────────── */
  .lp-problems {
    background: var(--color-bg);
    padding: clamp(4rem, 7vw, 6rem) var(--padding-x);
  }
  .lp-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .lp-section-header .section-title {
    max-width: 560px;
    margin-inline: auto;
  }
  .lp-problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .lp-problem-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    padding: 2.25rem 1.75rem;
    box-shadow: var(--shadow-sm);
    border-top: 3px solid var(--color-accent-gold);
    transition: var(--transition);
  }
  .lp-problem-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  .lp-problem-icon {
    width: 44px;
    height: 44px;
    color: var(--color-accent-gold);
    margin-bottom: 1.25rem;
  }
  .lp-problem-icon svg { width: 100%; height: 100%; }
  .lp-problem-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
