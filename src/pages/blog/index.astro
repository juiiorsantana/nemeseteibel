---
// src/pages/blog/index.astro
// Listagem de todos os artigos do blog
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function avatarInfo(author: string) {
  return author === 'Manuela Nemes'
    ? { initials: 'MN', cls: 'av-mn' }
    : { initials: 'PT', cls: 'av-pt' };
}
---

<Layout
  title="Insights Jurídicos | Nemes & Teibel Advogados"
  description="Artigos sobre Direito Agrário, Fundiário e Ambiental em Mato Grosso. Atualizações legislativas e orientações práticas para o produtor rural."
>

  <!-- ── Hero da página ─── -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <p class="blog-hero-eyebrow reveal">Nemes &amp; Teibel · Escritório</p>
      <h1 class="blog-hero-title reveal reveal-d1">Insights Jurídicos</h1>
      <p class="blog-hero-sub reveal reveal-d2">
        Atualizações sobre Direito Agrário, Fundiário e Ambiental — escritas para quem vive do campo.
      </p>
      <div class="blog-hero-divider reveal reveal-d3" aria-hidden="true"></div>
    </div>
  </section>

  <!-- ── Grade de posts ─── -->
  <section class="blog-list" aria-label="Artigos">
    <div class="container">

      <div class="blog-grid">
        {posts.map((post) => {
          const av = avatarInfo(post.data.author);
          return (
            <article class="blog-card reveal">
              <a href={`/blog/${post.slug}/`} class="blog-card-img-link" tabindex="-1" aria-hidden="true">
                <div class="blog-card-img-wrap">
                  <img
                    src={post.data.img}
                    alt={post.data.imgAlt}
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="375"
                  />
                  <span class="blog-tag">{post.data.tag}</span>
                </div>
              </a>

              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <rect x="3" y="4" width="18" height="18" rx="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/>
                      <line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    {post.data.date}
                  </span>
                  <span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {post.data.readTime}
                  </span>
                </div>

                <h2 class="blog-card-title">
                  <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                </h2>
                <p class="blog-card-excerpt">{post.data.excerpt}</p>

                <div class="blog-card-footer">
                  <div class="blog-author">
                    <span class={`avatar ${av.cls}`} aria-hidden="true">{av.initials}</span>
                    <span class="author-name">{post.data.author}</span>
                  </div>
                  <a href={`/blog/${post.slug}/`} class="read-more" aria-label={`Ler artigo: ${post.data.title}`}>
                    Ler artigo →
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>

  <!-- ── CTA final ─── -->
  <section class="blog-cta" aria-label="Contato">
    <div class="blog-cta-inner reveal">
      <p class="blog-cta-text">Tem uma dúvida jurídica sobre sua propriedade rural?</p>
      <a
        href="https://wa.me/556541410010?text=Vim%20pelo%20site!%20Tenho%20uma%20d%C3%BAvida%20jur%C3%ADdica%20sobre%20minha%20propriedade%20rural."
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green"
        aria-label="Fale com nossas especialistas pelo WhatsApp"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" style="flex-shrink:0">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Falar com uma especialista
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ────────────────────────────────────────── */
  .blog-hero {
    background: var(--color-bg-green);
    padding: clamp(5rem, 10vw, 8rem) var(--padding-x) clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid rgba(100, 120, 60, 0.12);
  }
  .blog-hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .blog-hero-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-gold);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .blog-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .blog-hero-sub {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--color-text-light);
    max-width: 560px;
    line-height: 1.7;
  }
  .blog-hero-divider {
    width: 48px;
    height: 3px;
    background: var(--color-accent-gold);
    border-radius: 2px;
    margin-top: 1.75rem;
  }

  /* ── Lista ───────────────────────────────────────── */
  .blog-list {
    background: var(--color-bg);
    padding: clamp(3.5rem, 7vw, 5.5rem) var(--padding-x);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
  }

  /* ── Card ────────────────────────────────────────── */
  .blog-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }
  .blog-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }

  .blog-card-img-link { display: block; }
  .blog-card-img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .blog-card-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .blog-card:hover .blog-card-img-wrap img { transform: scale(1.05); }

  .blog-tag {
    position: absolute;
    top: 1rem; left: 1rem;
    background: rgba(255,255,255,0.93);
    backdrop-filter: blur(4px);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary);
    padding: 0.35rem 0.875rem;
    border-radius: 50px;
  }

  .blog-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .blog-card-meta span { display: flex; align-items: center; gap: 0.3rem; }

  .blog-card-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.4;
  }
  .blog-card-title a {
    color: inherit;
    transition: color 0.25s ease;
  }
  .blog-card-title a:hover { color: var(--color-accent-dark); }

  .blog-card-excerpt {
    font-size: 0.855rem;
    color: var(--color-text-light);
    line-height: 1.65;
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.25rem;
  }
  .blog-author { display: flex; align-items: center; gap: 0.6rem; }
  .avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.68rem; font-weight: 700;
    color: var(--color-white);
    flex-shrink: 0;
  }
  .av-mn { background: #5A6B3A; }
  .av-pt { background: #3A6B5A; }
  .author-name { font-size: 0.84rem; font-weight: 500; color: var(--color-text); }

  .read-more {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: var(--transition);
  }
  .blog-card:hover .read-more { color: var(--color-accent-dark); }

  /* ── CTA final ───────────────────────────────────── */
  .blog-cta {
    background: var(--color-bg-green);
    padding: clamp(3rem, 6vw, 5rem) var(--padding-x);
    border-top: 1px solid rgba(100, 120, 60, 0.12);
  }
  .blog-cta-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .blog-cta-text {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--color-secondary);
    font-weight: 700;
    line-height: 1.3;
  }

  /* ── Responsivo ──────────────────────────────────── */
  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
    .blog-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
