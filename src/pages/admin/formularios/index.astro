---
export const prerender = false;

const user = Astro.locals.user;
const supabase = Astro.locals.supabase;

interface Form {
  id: string;
  name: string;
  title: string;
  subtitle: string | null;
  source_tag: string;
  service_interest: string | null;
  success_message: string;
  is_active: boolean;
  created_at: string;
}

const { data: forms, error } = await supabase
  .from('forms')
  .select('*')
  .order('created_at', { ascending: false });

const formList: Form[] = (forms ?? []) as Form[];

// Contar submissões por source_tag
const sourceTags = formList.map(f => f.source_tag);
let submissionCounts: Record<string, number> = {};

if (sourceTags.length > 0) {
  const { data: counts } = await supabase
    .from('contacts')
    .select('source')
    .in('source', sourceTags);

  (counts ?? []).forEach((row: { source: string }) => {
    submissionCounts[row.source] = (submissionCounts[row.source] ?? 0) + 1;
  });
}

const siteUrl = Astro.url.origin;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Formulários — Nemes & Teibel Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: #F0EDE6;
      min-height: 100vh;
      color: #3D3828;
    }

    .topbar {
      background: #3A3426;
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .topbar-left { display: flex; align-items: center; gap: 1.5rem; }

    .topbar-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
      color: #F5F0E8;
      font-weight: 700;
      text-decoration: none;
    }

    .topbar-brand span { color: #B8972A; }

    .topbar-nav { display: flex; gap: 0.25rem; }

    .nav-link {
      font-size: 0.82rem;
      color: rgba(245, 240, 232, 0.6);
      text-decoration: none;
      padding: 0.35rem 0.75rem;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .nav-link:hover { color: #F5F0E8; background: rgba(245,240,232,0.08); }
    .nav-link.active { color: #F5F0E8; background: rgba(245,240,232,0.12); }

    .topbar-right { display: flex; align-items: center; gap: 1rem; }

    .user-badge { font-size: 0.8rem; color: rgba(245, 240, 232, 0.65); }

    .btn-logout {
      background: transparent;
      border: 1px solid rgba(245, 240, 232, 0.3);
      color: #F5F0E8;
      padding: 0.4rem 0.875rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
    }

    .btn-logout:hover { background: rgba(245, 240, 232, 0.1); }

    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      color: #F5F0E8;
    }

    .hamburger svg { display: block; }

    .mobile-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(58, 52, 38, 0.5);
      z-index: 199;
    }

    .mobile-overlay.open { display: block; }

    .mobile-drawer {
      display: none;
      position: fixed;
      top: 0;
      right: 0;
      width: 260px;
      height: 100%;
      background: #3A3426;
      z-index: 200;
      padding: 1.25rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      overflow-y: auto;
    }

    .mobile-drawer.open {
      display: block;
      transform: translateX(0);
    }

    .drawer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(245, 240, 232, 0.1);
    }

    .drawer-header span {
      font-size: 0.8rem;
      color: rgba(245, 240, 232, 0.65);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 170px;
    }

    .drawer-close {
      background: none;
      border: none;
      color: #F5F0E8;
      cursor: pointer;
      padding: 0.25rem;
    }

    .drawer-nav {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      margin-bottom: 1.5rem;
    }

    .drawer-nav a {
      font-size: 0.9rem;
      color: rgba(245, 240, 232, 0.7);
      text-decoration: none;
      padding: 0.7rem 0.75rem;
      border-radius: 8px;
      transition: all 0.2s;
    }

    .drawer-nav a:hover { color: #F5F0E8; background: rgba(245, 240, 232, 0.08); }
    .drawer-nav a.active { color: #F5F0E8; background: rgba(245, 240, 232, 0.12); }

    .drawer-logout .btn-logout {
      width: 100%;
      text-align: center;
      padding: 0.6rem;
    }

    @media (max-width: 768px) {
      .topbar { padding: 0 1rem; }
      .topbar-nav { display: none; }
      .topbar-right { display: none; }
      .hamburger { display: block; }
    }

    .main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }

    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      color: #3A3426;
      font-weight: 700;
    }

    .page-header p {
      font-size: 0.875rem;
      color: #9A9285;
      margin-top: 0.25rem;
    }

    .btn-primary {
      background: #3A3426;
      color: #F5F0E8;
      border: none;
      padding: 0.6rem 1.25rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .btn-primary:hover { background: #4a4132; }

    .table-card {
      background: #fff;
      border-radius: 14px;
      box-shadow: 0 2px 8px rgba(58, 52, 38, 0.08);
      overflow: hidden;
    }

    .table-header {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid rgba(58, 52, 38, 0.08);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .table-header h2 { font-size: 0.95rem; font-weight: 700; color: #3A3426; }

    .count {
      font-size: 0.78rem;
      background: #F5F0E8;
      color: #8C7355;
      padding: 0.25rem 0.625rem;
      border-radius: 50px;
      font-weight: 600;
    }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      text-align: left;
      font-size: 0.72rem;
      font-weight: 700;
      color: #9A9285;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid rgba(58, 52, 38, 0.08);
    }

    tbody tr { transition: background 0.15s; }
    tbody tr:hover { background: #FAFAF8; }

    tbody td {
      padding: 0.875rem 1.5rem;
      font-size: 0.875rem;
      border-bottom: 1px solid rgba(58, 52, 38, 0.06);
      color: #3D3828;
    }

    tbody tr:last-child td { border-bottom: none; }

    .td-name { font-weight: 600; }
    .td-tag { font-family: monospace; font-size: 0.78rem; color: #8C7355; background: #F5F0E8; padding: 0.2rem 0.5rem; border-radius: 4px; }

    .status-dot {
      display: inline-block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      margin-right: 0.4rem;
    }

    .actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }

    .btn-action {
      padding: 0.35rem 0.7rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      border: 1.5px solid transparent;
      transition: all 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    .btn-link {
      background: #EFF6FF;
      color: #1D4ED8;
      border-color: #BFDBFE;
    }

    .btn-link:hover { background: #DBEAFE; }

    .btn-iframe {
      background: #F5F0E8;
      color: #8C7355;
      border-color: #E5DDD0;
    }

    .btn-iframe:hover { background: #EDE6D8; }

    .btn-toggle-on {
      background: #FEF9EE;
      color: #B45309;
      border-color: #FDE68A;
    }

    .btn-toggle-on:hover { background: #FEF3C7; }

    .btn-toggle-off {
      background: #F0FDF4;
      color: #166534;
      border-color: #BBF7D0;
    }

    .btn-toggle-off:hover { background: #DCFCE7; }

    .btn-delete {
      background: #FEF2F2;
      color: #DC2626;
      border-color: #FECACA;
    }

    .btn-delete:hover { background: #FEE2E2; }

    .empty-state {
      text-align: center;
      padding: 3.5rem 1.5rem;
      color: #9A9285;
    }

    .empty-state .icon { font-size: 2.25rem; margin-bottom: 0.75rem; }
    .empty-state p { font-size: 0.875rem; }

    /* Modal */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(58, 52, 38, 0.5);
      backdrop-filter: blur(3px);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }

    .modal-overlay.open { display: flex; }

    .modal {
      background: #fff;
      border-radius: 18px;
      width: 100%;
      max-width: 560px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 8px 40px rgba(58, 52, 38, 0.18);
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.5rem 1.75rem 1rem;
      border-bottom: 1px solid rgba(58, 52, 38, 0.08);
    }

    .modal-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: #3A3426;
    }

    .btn-close {
      background: none;
      border: none;
      font-size: 1.25rem;
      color: #9A9285;
      cursor: pointer;
      padding: 0.25rem;
      line-height: 1;
      border-radius: 6px;
      transition: background 0.15s;
    }

    .btn-close:hover { background: #F5F0E8; color: #3A3426; }

    .modal-body { padding: 1.5rem 1.75rem; }

    .form-grid { display: grid; gap: 1.1rem; }

    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #3A3426;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 0.65rem 0.875rem;
      border: 1.5px solid rgba(58, 52, 38, 0.18);
      border-radius: 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      color: #3D3828;
      background: #fafaf8;
      transition: border-color 0.2s;
      outline: none;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: #B8972A;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(184, 151, 42, 0.1);
    }

    .form-group textarea { resize: vertical; min-height: 70px; }

    .form-hint {
      font-size: 0.73rem;
      color: #9A9285;
      margin-top: 0.1rem;
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 0.75rem;
      padding: 1rem 1.75rem 1.5rem;
    }

    .btn-secondary {
      background: transparent;
      border: 1.5px solid rgba(58, 52, 38, 0.2);
      color: #3A3426;
      padding: 0.6rem 1.25rem;
      border-radius: 50px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }

    .btn-secondary:hover { background: #F5F0E8; }

    .modal-error {
      background: #FEF2F2;
      border: 1px solid rgba(220, 38, 38, 0.2);
      border-radius: 8px;
      padding: 0.65rem 1rem;
      font-size: 0.82rem;
      color: #DC2626;
      margin-bottom: 1rem;
    }

    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      background: #3A3426;
      color: #F5F0E8;
      padding: 0.75rem 1.25rem;
      border-radius: 10px;
      font-size: 0.85rem;
      font-weight: 500;
      box-shadow: 0 4px 16px rgba(58, 52, 38, 0.3);
      transform: translateY(8px);
      opacity: 0;
      transition: all 0.25s;
      z-index: 999;
      pointer-events: none;
    }

    .toast.show { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .main { padding: 1.25rem 1rem; }
      .page-header h1 { font-size: 1.35rem; }

      .table-card table,
      .table-card thead,
      .table-card tbody,
      .table-card th,
      .table-card td,
      .table-card tr { display: block; }
      .table-card thead { display: none; }
      .table-card tbody tr {
        padding: 1rem;
        border-bottom: 1px solid rgba(58, 52, 38, 0.1);
      }
      .table-card tbody tr:last-child { border-bottom: none; }
      .table-card tbody td {
        padding: 0.25rem 0;
        border-bottom: none;
        font-size: 0.85rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .table-card tbody td::before {
        content: attr(data-label);
        font-size: 0.7rem;
        font-weight: 700;
        color: #9A9285;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        min-width: 90px;
        flex-shrink: 0;
      }
      .actions {
        justify-content: flex-start;
        margin-top: 0.5rem;
      }
      .modal {
        max-width: 100%;
        margin: 0.5rem;
        border-radius: 14px;
      }
      .form-row { grid-template-columns: 1fr; }
      .modal-header { padding: 1.25rem 1.25rem 0.75rem; }
      .modal-body { padding: 1rem 1.25rem; }
      .modal-footer { padding: 0.75rem 1.25rem 1.25rem; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-left">
      <a href="/admin" class="topbar-brand">Nemes <span>&</span> Teibel — Admin</a>
      <nav class="topbar-nav">
        <a href="/admin" class="nav-link">Dashboard</a>
        <a href="/admin/materiais" class="nav-link">Materiais</a>
        <a href="/admin/formularios" class="nav-link active">Formulários</a>
        <a href="/admin/usuarios" class="nav-link">Usuários</a>
      </nav>
    </div>
    <div class="topbar-right">
      <span class="user-badge">{user?.email}</span>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="btn-logout">Sair</button>
      </form>
    </div>
    <button class="hamburger" id="hamburger-btn" aria-label="Abrir menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </header>

  <div class="mobile-overlay" id="mobile-overlay"></div>
  <div class="mobile-drawer" id="mobile-drawer">
    <div class="drawer-header">
      <span>{user?.email}</span>
      <button class="drawer-close" id="drawer-close" aria-label="Fechar menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="drawer-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/materiais">Materiais</a>
      <a href="/admin/formularios" class="active">Formulários</a>
      <a href="/admin/usuarios">Usuários</a>
    </nav>
    <div class="drawer-logout">
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="btn-logout">Sair</button>
      </form>
    </div>
  </div>

  <main class="main">
    <div class="page-header">
      <div>
        <h1>Formulários</h1>
        <p>Crie e distribua formulários de captura de leads</p>
      </div>
      <button class="btn-primary" id="btn-open-modal">+ Novo formulário</button>
    </div>

    <div class="table-card">
      <div class="table-header">
        <h2>Formulários criados</h2>
        <span class="count">{formList.length} registros</span>
      </div>

      {formList.length === 0 ? (
        <div class="empty-state">
          <div class="icon">📋</div>
          <p>Nenhum formulário criado ainda. Clique em "Novo formulário" para começar.</p>
        </div>
      ) : (
        <table>
          <thead>
            <tr>
              <th>Nome interno</th>
              <th>Título público</th>
              <th>Source tag</th>
              <th>Submissões</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            {formList.map((f) => (
              <tr>
                <td class="td-name" data-label="Nome">{f.name}</td>
                <td data-label="Título">{f.title}</td>
                <td data-label="Source tag"><span class="td-tag">{f.source_tag}</span></td>
                <td data-label="Submissões">{submissionCounts[f.source_tag] ?? 0}</td>
                <td data-label="Status">
                  <span class="status-dot" style={`background:${f.is_active ? '#3DBE4F' : '#9A9285'}`}></span>
                  {f.is_active ? 'Ativo' : 'Inativo'}
                </td>
                <td data-label="Ações">
                  <div class="actions">
                    <button
                      class="btn-action btn-link"
                      data-copy={`${siteUrl}/f/${f.id}`}
                      onclick="copyText(this)"
                    >
                      Link
                    </button>
                    <button
                      class="btn-action btn-iframe"
                      data-copy={`<iframe src="${siteUrl}/f/${f.id}?embed=1" width="100%" height="480" frameborder="0" style="border-radius:12px;border:none;" title="${f.title}"></iframe>`}
                      onclick="copyText(this)"
                    >
                      Iframe
                    </button>
                    <button
                      class="btn-action"
                      class:list={[f.is_active ? 'btn-toggle-on' : 'btn-toggle-off']}
                      data-id={f.id}
                      data-active={String(f.is_active)}
                      onclick="toggleForm(this)"
                    >
                      {f.is_active ? 'Desativar' : 'Ativar'}
                    </button>
                    <button
                      class="btn-action btn-delete"
                      data-id={f.id}
                      data-name={f.name}
                      onclick="deleteForm(this)"
                    >
                      Excluir
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </main>

  <!-- Modal de criação -->
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-header">
        <h2 id="modal-title">Novo formulário</h2>
        <button class="btn-close" id="btn-close-modal" aria-label="Fechar">✕</button>
      </div>
      <div class="modal-body">
        <div id="modal-error" class="modal-error" style="display:none"></div>
        <form id="create-form" class="form-grid" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="f-name">Nome interno *</label>
              <input type="text" id="f-name" placeholder="Ex: Blog - Regularização" required />
              <span class="form-hint">Visível apenas para você no painel</span>
            </div>
            <div class="form-group">
              <label for="f-source-tag">Source tag *</label>
              <input type="text" id="f-source-tag" placeholder="blog-regularizacao" required />
              <span class="form-hint">Identificador único nos leads</span>
            </div>
          </div>

          <div class="form-group">
            <label for="f-title">Título público *</label>
            <input type="text" id="f-title" placeholder="Ex: Fale com um especialista" required />
          </div>

          <div class="form-group">
            <label for="f-subtitle">Subtítulo</label>
            <input type="text" id="f-subtitle" placeholder="Ex: Respondemos em até 24h" />
          </div>

          <div class="form-group">
            <label for="f-service">Serviço de interesse</label>
            <input type="text" id="f-service" placeholder="Ex: regularizacao-fundiaria" />
            <span class="form-hint">Salvo em cada lead captado por este formulário</span>
          </div>

          <div class="form-group">
            <label for="f-success">Mensagem de sucesso</label>
            <textarea id="f-success" placeholder="Obrigado! Entraremos em contato em breve."></textarea>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" id="btn-cancel">Cancelar</button>
        <button class="btn-primary" id="btn-create">Criar formulário</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    const overlay = document.getElementById('modal-overlay');
    const btnOpen = document.getElementById('btn-open-modal');
    const btnClose = document.getElementById('btn-close-modal');
    const btnCancel = document.getElementById('btn-cancel');
    const btnCreate = document.getElementById('btn-create');
    const modalError = document.getElementById('modal-error');
    const toast = document.getElementById('toast');

    let toastTimer: ReturnType<typeof setTimeout>;

    function showToast(msg: string) {
      toast.textContent = msg;
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('show'), 2500);
    }

    function openModal() {
      overlay.classList.add('open');
      document.getElementById('f-name').focus();
    }

    function closeModal() {
      overlay.classList.remove('open');
      (document.getElementById('create-form') as HTMLFormElement).reset();
      modalError.style.display = 'none';
    }

    btnOpen.addEventListener('click', openModal);
    btnClose.addEventListener('click', closeModal);
    btnCancel.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });

    // Auto-gerar source_tag a partir do nome interno
    document.getElementById('f-name').addEventListener('input', (e) => {
      const tagInput = document.getElementById('f-source-tag') as HTMLInputElement;
      if (!tagInput.dataset.edited) {
        const val = (e.target as HTMLInputElement).value
          .toLowerCase()
          .normalize('NFD').replace(/[̀-ͯ]/g, '')
          .replace(/[^a-z0-9\s-]/g, '')
          .trim()
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
        tagInput.value = val;
      }
    });

    document.getElementById('f-source-tag').addEventListener('input', function() {
      (this as HTMLInputElement).dataset.edited = '1';
    });

    btnCreate.addEventListener('click', async () => {
      const name = (document.getElementById('f-name') as HTMLInputElement).value.trim();
      const title = (document.getElementById('f-title') as HTMLInputElement).value.trim();
      const subtitle = (document.getElementById('f-subtitle') as HTMLInputElement).value.trim() || null;
      const sourceTag = (document.getElementById('f-source-tag') as HTMLInputElement).value.trim();
      const service = (document.getElementById('f-service') as HTMLInputElement).value.trim() || null;
      const successMsg = (document.getElementById('f-success') as HTMLTextAreaElement).value.trim() || 'Obrigado! Entraremos em contato em breve.';

      if (!name || !title || !sourceTag) {
        modalError.textContent = 'Nome interno, título e source tag são obrigatórios.';
        modalError.style.display = 'block';
        return;
      }

      btnCreate.textContent = 'Criando…';
      (btnCreate as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/forms/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, title, subtitle, source_tag: sourceTag, service_interest: service, success_message: successMsg }),
        });

        const data = await res.json();

        if (!res.ok) {
          modalError.textContent = data.error ?? 'Erro ao criar formulário.';
          modalError.style.display = 'block';
          btnCreate.textContent = 'Criar formulário';
          (btnCreate as HTMLButtonElement).disabled = false;
          return;
        }

        closeModal();
        showToast('Formulário criado com sucesso!');
        setTimeout(() => location.reload(), 800);
      } catch {
        modalError.textContent = 'Erro de conexão.';
        modalError.style.display = 'block';
        btnCreate.textContent = 'Criar formulário';
        (btnCreate as HTMLButtonElement).disabled = false;
      }
    });

    function copyText(btn: HTMLButtonElement) {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copiado!';
        setTimeout(() => { btn.textContent = orig; }, 1800);
      });
    }

    async function toggleForm(btn: HTMLButtonElement) {
      const id = btn.dataset.id;
      const active = btn.dataset.active === 'true';
      btn.disabled = true;

      const res = await fetch('/api/forms/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, is_active: !active }),
      });

      if (res.ok) {
        showToast(active ? 'Formulário desativado.' : 'Formulário ativado.');
        setTimeout(() => location.reload(), 600);
      } else {
        showToast('Erro ao alterar status.');
        btn.disabled = false;
      }
    }

    async function deleteForm(btn: HTMLButtonElement) {
      const name = btn.dataset.name;
      if (!confirm(`Excluir o formulário "${name}"?\n\nOs leads já capturados não serão removidos.`)) return;

      const id = btn.dataset.id;
      btn.disabled = true;

      const res = await fetch(`/api/forms/${id}`, { method: 'DELETE' });

      if (res.ok) {
        showToast('Formulário excluído.');
        setTimeout(() => location.reload(), 600);
      } else {
        showToast('Erro ao excluir formulário.');
        btn.disabled = false;
      }
    }

    (window as any).copyText = copyText;
    (window as any).toggleForm = toggleForm;
    (window as any).deleteForm = deleteForm;

    // Mobile drawer
    const hamburger = document.getElementById('hamburger-btn');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const drawer = document.getElementById('mobile-drawer');
    const drawerClose = document.getElementById('drawer-close');

    function openDrawer() {
      mobileOverlay?.classList.add('open');
      drawer?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      mobileOverlay?.classList.remove('open');
      drawer?.classList.remove('open');
      document.body.style.overflow = '';
    }
    hamburger?.addEventListener('click', openDrawer);
    mobileOverlay?.addEventListener('click', closeDrawer);
    drawerClose?.addEventListener('click', closeDrawer);
  </script>
</body>
</html>
