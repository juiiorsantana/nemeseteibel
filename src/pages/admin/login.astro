---
export const prerender = false;

const supabase = Astro.locals.supabase;

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = String(formData.get('email') ?? '');
  const password = String(formData.get('password') ?? '');

  const { error } = await supabase.auth.signInWithPassword({ email, password });

  if (error) {
    errorMessage = 'E-mail ou senha incorretos.';
  } else {
    return Astro.redirect('/admin');
  }
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Acesso Administrativo — Nemes & Teibel</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: #3A3426;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }

    .card {
      background: #F5F0E8;
      border-radius: 20px;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    }

    .brand {
      text-align: center;
      margin-bottom: 2rem;
    }

    .brand-name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      font-weight: 700;
      color: #3A3426;
      line-height: 1.2;
    }

    .brand-sub {
      font-size: 0.78rem;
      color: #8C7355;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 0.25rem;
    }

    .divider {
      width: 40px;
      height: 2px;
      background: #B8972A;
      margin: 1rem auto;
    }

    h1 {
      font-size: 0.9rem;
      font-weight: 500;
      color: #6B6355;
      text-align: center;
      margin-bottom: 1.75rem;
    }

    .field {
      margin-bottom: 1rem;
    }

    label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: #3A3426;
      margin-bottom: 0.4rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid rgba(58, 52, 38, 0.18);
      border-radius: 10px;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 0.95rem;
      color: #3D3828;
      background: #FAFAF8;
      transition: border-color 0.2s;
      outline: none;
    }

    input:focus {
      border-color: #8C7355;
    }

    .error {
      background: #fff0f0;
      border: 1px solid #f5c0c0;
      border-radius: 8px;
      padding: 0.65rem 0.875rem;
      font-size: 0.85rem;
      color: #c0392b;
      margin-bottom: 1rem;
    }

    button[type="submit"] {
      width: 100%;
      padding: 0.875rem;
      background: #3DBE4F;
      color: #fff;
      border: none;
      border-radius: 50px;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, transform 0.2s;
      margin-top: 0.5rem;
    }

    button[type="submit"]:hover {
      background: #2EA040;
      transform: translateY(-1px);
    }

    .back-link {
      display: block;
      text-align: center;
      margin-top: 1.25rem;
      font-size: 0.8rem;
      color: #9A9285;
      text-decoration: none;
    }

    .back-link:hover { color: #8C7355; }
  </style>
</head>
<body>
  <div class="card">
    <div class="brand">
      <div class="brand-name">Nemes & Teibel</div>
      <div class="brand-sub">Advogados Associados</div>
      <div class="divider"></div>
      <h1>Acesso Administrativo</h1>
    </div>

    {errorMessage && (
      <div class="error">{errorMessage}</div>
    )}

    <form method="POST">
      <div class="field">
        <label for="email">E-mail</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="admin@nemeseteibeladv.com.br"
        />
      </div>

      <div class="field">
        <label for="password">Senha</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          autocomplete="current-password"
          placeholder="••••••••"
        />
      </div>

      <button type="submit">Entrar</button>
    </form>

    <a href="/" class="back-link">← Voltar ao site</a>
  </div>
</body>
</html>
