<script>
  // ── Formulário de isca digital ───────────────────────────────────
  const MATERIAL_ID = 'ca3f57e9-765a-457b-b0d6-17374bbc1726';

  const form = document.getElementById('lp-lead-form') as HTMLFormElement | null;
  if (form) {
    const fieldEmail = document.getElementById('field-email') as HTMLDivElement | null;
    const fieldWa    = document.getElementById('field-whatsapp') as HTMLDivElement | null;
    const radios     = form.querySelectorAll('input[name="contact-type"]') as NodeListOf<HTMLInputElement>;

    radios.forEach(radio => {
      radio.addEventListener('change', () => {
        if (radio.value === 'email') {
          fieldEmail?.removeAttribute('hidden');
          fieldWa?.setAttribute('hidden', '');
        } else {
          fieldWa?.removeAttribute('hidden');
          fieldEmail?.setAttribute('hidden', '');
        }
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nomeEl     = form.querySelector('#lead-nome') as HTMLInputElement;
      const nome       = nomeEl.value.trim();
      const activeType = (form.querySelector('input[name="contact-type"]:checked') as HTMLInputElement)?.value;
      const contactEl  = form.querySelector(activeType === 'email' ? '#lead-email' : '#lead-whatsapp') as HTMLInputElement;
      const contact    = contactEl?.value.trim() ?? '';

      let valid = true;
      if (!nome)    { nomeEl.classList.add('error');    valid = false; } else nomeEl.classList.remove('error');
      if (!contact) { contactEl.classList.add('error'); valid = false; } else contactEl.classList.remove('error');
      if (!valid) return;

      const btn = form.querySelector('.lp-lead-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Gerando link…';

      try {
        const res = await fetch('/api/materials/download', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            material_id: MATERIAL_ID,
            name: nome,
            email: activeType === 'email' ? contact : '',
            phone: activeType === 'whatsapp' ? contact : '',
            source: 'lp-due-diligence',
          }),
        });

        const data = await res.json();

        if (res.ok && data.signedUrl) {
          window.open(data.signedUrl, '_blank', 'noopener,noreferrer');
          btn.textContent = '✓ Download iniciado!';
        } else {
          btn.textContent = 'Erro — tente novamente';
          btn.disabled = false;
          return;
        }
      } catch {
        btn.textContent = 'Erro — tente novamente';
        btn.disabled = false;
        return;
      }

      setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg> Baixar cartilha grátis`;
      }, 4000);
    });
  }
</script>
