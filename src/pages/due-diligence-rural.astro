---
export const prerender = false;
// src/pages/due-diligence-rural.astro
// LP — Due Diligence Rural | Nemes & Teibel Advogados
// Tráfego: Google Ads (noindex via LPLayout)
// CTA único: WhatsApp
import LPLayout from '../layouts/LPLayout.astro';

const WA = 'https://wa.me/556541410010?text=Vim%20pelo%20site!%20Quero%20fazer%20a%20Due%20Diligence%20da%20minha%20propriedade%20rural.';

const problems = [
  {
    title: 'Embargo ambiental escondido',
    text: 'A área parece produtiva, mas tem um embargo que pode travar a operação. A gente descobre isso antes de você assinar.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
    </svg>`,
    delay: 'reveal-d1',
  },
  {
    title: 'Área no papel diferente da área real',
    text: 'Muitas fazendas têm divergência entre o que está registrado e o que está cercado. Isso gera conflito, perda patrimonial e dificuldade de financiamento.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" />
    </svg>`,
    delay: 'reveal-d2',
  },
  {
    title: 'Vendedor com dívidas que recaem no imóvel',
    text: 'Ações judiciais, execuções e fraude contra credores podem comprometer a compra mesmo depois que o contrato estiver assinado.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c-.99.143-1.99.317-3 .52m3-.52L5.25 15.696c-.122.499.106 1.028.589 1.202a5.989 5.989 0 002.031.352 5.989 5.989 0 002.031-.352c.483-.174.711-.703.59-1.202L5.25 4.971z" />
    </svg>`,
    delay: 'reveal-d3',
  },
];
---

<LPLayout
  title="Due Diligence Rural em MT | Nemes & Teibel Advogados"
  description="Antes de comprar uma fazenda, faça a Due Diligence Rural. Descubra embargos, irregularidades e riscos ocultos. Fale com especialista em MT."
>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCOS 01 + 02 + 03 — Hero                                     -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-hero" aria-label="Due Diligence Rural — apresentação">

    <img
      class="lp-hero-bg"
      src="/img/bg1.avif"
      alt=""
      aria-hidden="true"
      width="1920"
      height="1000"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="lp-hero-overlay" aria-hidden="true"></div>

    <div class="lp-hero-content">
      <h1 class="lp-hero-h1 reveal">
        Due Diligence Rural: descubra os riscos antes de comprar sua fazenda
      </h1>
      <p class="lp-hero-sub reveal reveal-d1">
        Evite cair em fraudes e ter prejuízos milionários com uma investigação jurídica completa antes de assinar qualquer contrato.
      </p>
      <p class="lp-hero-support reveal reveal-d2">
        Fale agora com uma especialista em Direito Agrário
      </p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-green lp-hero-cta reveal reveal-d3"
        aria-label="Quero fazer a Due Diligence da minha propriedade — WhatsApp"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
        </svg>
        Quero fazer a Due Diligence da minha propriedade
      </a>
    </div>

  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 04 — Credenciais em destaque                             -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-creds" aria-label="Credenciais da especialista">
    <div class="lp-creds-inner">

      <div class="lp-cred reveal reveal-d1">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>+ de 10 anos com atuação exclusiva em Agrário, Fundiário e Ambiental</span>
      </div>

      <div class="lp-cred-divider" aria-hidden="true"></div>

      <div class="lp-cred reveal reveal-d2">
        <span class="lp-cred-check" aria-hidden="true">✔</span>
        <span>Advogadas especialistas em Agrário e Ambiental</span>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 05 — Problemas que Resolvemos                            -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-problems" aria-labelledby="lp-problems-heading">
    <div class="container">

      <header class="lp-section-header">
        <h2 id="lp-problems-heading" class="section-title reveal">
          Antes de fechar negócio, você sabe o que está comprando de verdade?
        </h2>
      </header>

      <div class="lp-problems-grid">
        {problems.map((p) => (
          <article class={`lp-problem-card reveal ${p.delay}`}>
            <div class="lp-problem-icon" set:html={p.icon} />
            <h3 class="lp-problem-title">{p.title}</h3>
            <p class="lp-problem-text">{p.text}</p>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 06 — Prova Social                                        -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-social" aria-label="Resultados e depoimentos">
    <div class="lp-social-inner">

      <!-- Coluna esquerda: texto de impacto -->
      <div class="lp-social-text">

        <div class="lp-social-badge reveal">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Caso real
        </div>

        <blockquote class="lp-impact reveal reveal-d1">
          <span class="lp-impact-quotes" aria-hidden="true">"</span>
          Um cliente quase perdeu milhões de reais — a Due Diligence evitou.
        </blockquote>

        <p class="lp-social-sub reveal reveal-d2">
          Dezenas de negócios analisados em Mato Grosso e Centro-Oeste. Cada investigação feita antes do contrato é uma compra protegida.
        </p>

        <div class="lp-social-stats reveal reveal-d3" aria-label="Números do escritório">
          <div class="lp-stat">
            <span class="lp-stat-num">20+</span>
            <span class="lp-stat-label">anos de atuação</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">MT</span>
            <span class="lp-stat-label">e Centro-Oeste</span>
          </div>
          <div class="lp-stat-divider" aria-hidden="true"></div>
          <div class="lp-stat">
            <span class="lp-stat-num">100%</span>
            <span class="lp-stat-label">foco no campo</span>
          </div>
        </div>

      </div>

      <!-- Coluna direita: vídeo Instagram -->
      <div class="lp-social-reel reveal reveal-d2">
        <div class="lp-reel-wrap">
          <blockquote
            class="instagram-media"
            data-instgrm-permalink="https://www.instagram.com/p/DOMVPoIAWnB/?utm_source=ig_embed&utm_campaign=loading"
            data-instgrm-version="14"
          ></blockquote>
          <script async src="https://www.instagram.com/embed.js"></script>
        </div>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 06B — Isca Digital: Cartilha                             -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-lead" aria-labelledby="lp-lead-heading">
    <div class="lp-lead-glow" aria-hidden="true"></div>

    <div class="lp-lead-inner">

      <!-- Coluna texto + form -->
      <div class="lp-lead-content reveal">
        <div class="lp-lead-header">
          <span class="lp-lead-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            Material gratuito
          </span>
          <h2 id="lp-lead-heading" class="lp-lead-title">
            Baixe a cartilha gratuita antes de assinar qualquer contrato
          </h2>
          <p class="lp-lead-sub">
            Um guia prático sobre o que verificar na compra e venda de imóvel rural — escrito pelas especialistas do escritório.
          </p>
        </div>

        <div class="lp-lead-card reveal reveal-d1">
          <form class="lp-lead-form" id="lp-lead-form" novalidate>
            <div class="lp-field">
              <label for="lead-nome">Nome completo</label>
              <input
                type="text"
                id="lead-nome"
                name="nome"
                placeholder="Seu nome"
                required
                autocomplete="name"
              />
            </div>

            <div class="lp-contact-toggle" role="group" aria-label="Como prefere receber">
              <span class="lp-toggle-label">Receber por</span>
              <div class="lp-toggle-options">
                <label class="lp-toggle-opt">
                  <input type="radio" name="contact-type" value="email" checked />
                  <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                    E-mail
                  </span>
                </label>
                <label class="lp-toggle-opt">
                  <input type="radio" name="contact-type" value="whatsapp" />
                  <span>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
                    WhatsApp
                  </span>
                </label>
              </div>
            </div>

            <div class="lp-field" id="field-email">
              <label for="lead-email">E-mail</label>
              <input
                type="email"
                id="lead-email"
                name="email"
                placeholder="seu@email.com"
                autocomplete="email"
              />
            </div>
            <div class="lp-field" id="field-whatsapp" hidden>
              <label for="lead-whatsapp">WhatsApp</label>
              <input
                type="tel"
                id="lead-whatsapp"
                name="whatsapp"
                placeholder="(65) 99999-9999"
                autocomplete="tel"
              />
            </div>

            <button type="submit" class="btn btn-green lp-lead-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
              </svg>
              Baixar cartilha grátis
            </button>

            <p class="lp-lead-privacy">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
              Seus dados estão seguros. Não enviamos spam.
            </p>
          </form>
        </div>
      </div>

      <!-- Mockup da cartilha -->
      <div class="lp-lead-mockup reveal reveal-d2">
        <div class="lp-mockup-book">
          <div class="lp-mockup-spine" aria-hidden="true"></div>
          <div class="lp-mockup-cover">
            <div class="lp-mockup-cover-top">
              <span class="lp-mockup-tag">Guia gratuito</span>
              <div class="lp-mockup-logo-line" aria-hidden="true"></div>
            </div>
            <div class="lp-mockup-cover-body">
              <p class="lp-mockup-title">Cartilha de<br/>Compra e Venda<br/>de Imóvel Rural</p>
              <p class="lp-mockup-sub">O que verificar antes de assinar</p>
            </div>
            <div class="lp-mockup-cover-bottom">
              <span>Nemes &amp; Teibel Advogados</span>
            </div>
          </div>
        </div>
        <div class="lp-mockup-shadow" aria-hidden="true"></div>
      </div>

    </div>
  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
  <!-- BLOCO 07 — Quem vai te atender                                 -->
  <!-- ────────────────────────────────────────────────────────────── -->
  <section class="lp-expert" aria-label="Sobre as advogadas especialistas">

    <!-- Paula Teibel — foto à esquerda -->
    <div class="container lp-expert-inner">

      <div class="lp-expert-photo-wrap reveal">
        <img
          src="/img/paula.avif"
          alt="Dra. Paula Teibel"
          class="lp-expert-photo"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="lp-expert-bio reveal reveal-d1">
        <p class="lp-expert-label">Quem vai te atender</p>
        <h2 class="lp-expert-name">Paula Teibel</h2>
        <p class="lp-expert-role">Advogada Especialista em Direito Agrário e Fundiário</p>
        <p class="lp-expert-text">
          Paula tem mais de 20 anos de atuação em Direito Agrário, Fundiário e Ambiental em Mato Grosso. Antes de advogar, foi servidora do INTERMAT — o Instituto de Terras do Estado — e conhece de perto como funciona a regularização fundiária no MT. Isso significa que, na Due Diligence, ela sabe exatamente onde procurar e o que os documentos realmente dizem.
        </p>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-green"
          aria-label="Falar com Paula Teibel pelo WhatsApp"
        >
          <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
          </svg>
          Falar com Paula Teibel
        </a>
      </div>

    </div>

    <div class="lp-expert-sep" aria-hidden="true"></div>

    <!-- Manuela Nemes — foto à direita -->
    <div class="container lp-expert-inner lp-expert-inner--reverse">

      <div class="lp-expert-bio reveal reveal-d1">
        <p class="lp-expert-label">Também no escritório</p>
        <h2 class="lp-expert-name">Manuela Nemes</h2>
        <p class="lp-expert-role">Advogada Especialista em Direito Agrário e Minerário</p>
        <p class="lp-expert-text">
          Manuela acumula mais de 15 anos de atuação em Direito Agrário, Fundiário e Agronegócio. Vice-Presidente da Comissão de Assuntos Fundiários da OAB/MT, ela alia consultoria preventiva, regularização fundiária e demandas ambientais ligadas ao setor mineral — um perfil raro que complementa a análise em cada due diligence realizada pelo escritório.
        </p>
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-green"
          aria-label="Falar com Manuela Nemes pelo WhatsApp"
        >
          <svg class="wa-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path fill="currentColor" d="M12 0C5.373 0 0 5.373 0 12c0 2.139.563 4.14 1.541 5.876L.057 23.887l6.156-1.616A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.8 9.8 0 01-4.992-1.363l-.358-.213-3.716.975.993-3.63-.234-.373A9.77 9.77 0 012.182 12c0-5.42 4.398-9.818 9.818-9.818 5.42 0 9.818 4.398 9.818 9.818 0 5.42-4.398 9.818-9.818 9.818z"/>
          </svg>
          Falar com Manuela Nemes
        </a>
      </div>

      <div class="lp-expert-photo-wrap reveal">
        <img
          src="/img/Manu.avif"
          alt="Dra. Manuela Nemes"
          class="lp-expert-photo"
          loading="lazy"
          decoding="async"
        />
      </div>

    </div>

  </section>

  <!-- ────────────────────────────────────────────────────────────── -->
