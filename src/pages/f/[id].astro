---
export const prerender = false;

const { id } = Astro.params;
const embed = Astro.url.searchParams.get('embed') === '1';

const { data: form, error } = await Astro.locals.supabase
  .from('forms')
  .select('id, title, subtitle, success_message')
  .eq('id', id!)
  .eq('is_active', true)
  .single();

if (error || !form) {
  return Astro.redirect('/404');
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{form.title} — Nemes & Teibel Advogados</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #B8972A;
      --dark: #3A3426;
      --cream: #F5F0E8;
      --bg: #F0EDE6;
      --muted: #9A9285;
      --text: #3D3828;
      --error: #C0392B;
      --success-bg: #F0F9F4;
      --success-color: #1E7E4A;
    }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      min-height: 100vh;
      color: var(--text);
      display: flex;
      flex-direction: column;
    }

    body.embed {
      background: transparent;
      min-height: unset;
    }

    .page-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
    }

    .embed .page-wrapper {
      padding: 1.25rem;
      justify-content: flex-start;
    }

    .brand {
      text-align: center;
      margin-bottom: 2rem;
    }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      color: var(--dark);
      font-weight: 700;
    }

    .brand-name span { color: var(--gold); }

    .brand-tagline {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 0.2rem;
      letter-spacing: 0.04em;
    }

    .card {
      background: #fff;
      border-radius: 18px;
      box-shadow: 0 4px 24px rgba(58, 52, 38, 0.1);
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 480px;
    }

    .embed .card {
      box-shadow: none;
      border-radius: 12px;
      padding: 1.75rem 1.5rem;
      border: 1px solid rgba(58, 52, 38, 0.1);
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--dark);
      line-height: 1.3;
      margin-bottom: 0.375rem;
    }

    .card-subtitle {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 1.75rem;
    }

    .field {
      margin-bottom: 1.1rem;
    }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--dark);
      margin-bottom: 0.4rem;
      letter-spacing: 0.01em;
    }

    input {
      width: 100%;
      padding: 0.7rem 0.9rem;
      border: 1.5px solid rgba(58, 52, 38, 0.18);
      border-radius: 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--text);
      background: #fafaf8;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    input:focus {
      border-color: var(--gold);
      background: #fff;
      box-shadow: 0 0 0 3px rgba(184, 151, 42, 0.1);
    }

    input.invalid {
      border-color: var(--error);
      box-shadow: 0 0 0 3px rgba(192, 57, 43, 0.08);
    }

    .field-error {
      font-size: 0.75rem;
      color: var(--error);
      margin-top: 0.3rem;
      min-height: 1rem;
    }

    .btn-submit {
      width: 100%;
      padding: 0.85rem;
      background: var(--dark);
      color: var(--cream);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      margin-top: 0.5rem;
    }

    .btn-submit:hover { background: #4a4132; }
    .btn-submit:active { transform: scale(0.99); }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

    .form-error {
      background: #FEF2F2;
      border: 1px solid rgba(192, 57, 43, 0.25);
      border-radius: 9px;
      padding: 0.75rem 1rem;
      font-size: 0.82rem;
      color: var(--error);
      margin-top: 0.75rem;
    }

    .success-state {
      text-align: center;
      padding: 1.5rem 0 0.5rem;
    }

    .success-icon {
      font-size: 2.5rem;
      display: block;
      margin-bottom: 0.75rem;
    }

    .success-msg {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--success-color);
      line-height: 1.5;
    }

    .success-sub {
      font-size: 0.82rem;
      color: var(--muted);
      margin-top: 0.4rem;
    }

    .privacy-note {
      text-align: center;
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 1.25rem;
    }

    .footer-link {
      display: block;
      text-align: center;
      font-size: 0.75rem;
      color: var(--muted);
      text-decoration: none;
      margin-top: 1.5rem;
      opacity: 0.7;
    }

    .footer-link:hover { opacity: 1; }
  </style>
</head>
<body class={embed ? 'embed' : ''}>
  <div class="page-wrapper">
    {!embed && (
      <div class="brand">
        <div class="brand-name">Nemes <span>&</span> Teibel</div>
        <div class="brand-tagline">Advogados Associados</div>
      </div>
    )}

    <div class="card">
      <div id="form-wrapper">
        <h1 class="card-title">{form.title}</h1>
        {form.subtitle && <p class="card-subtitle">{form.subtitle}</p>}

        <form id="contact-form" novalidate>
          <div class="field">
            <label for="name">Nome completo *</label>
            <input type="text" id="name" name="name" placeholder="Seu nome" autocomplete="name" />
            <div class="field-error" id="err-name"></div>
          </div>

          <div class="field">
            <label for="email">E-mail</label>
            <input type="email" id="email" name="email" placeholder="seu@email.com" autocomplete="email" />
            <div class="field-error" id="err-email"></div>
          </div>

          <div class="field">
            <label for="phone">WhatsApp</label>
            <input type="tel" id="phone" name="phone" placeholder="(00) 00000-0000" autocomplete="tel" maxlength="15" />
            <div class="field-error" id="err-phone"></div>
          </div>

          <div class="field-error" id="err-general" style="margin-top:0.25rem"></div>

          <button type="submit" class="btn-submit" id="btn-submit">Enviar mensagem</button>

          <div id="form-error" class="form-error" style="display:none"></div>
        </form>

        <p class="privacy-note">Seus dados são protegidos e usados apenas para retorno do escritório.</p>
      </div>

      <div id="success-wrapper" style="display:none" class="success-state">
        <span class="success-icon">✓</span>
        <p class="success-msg" id="success-msg">{form.success_message}</p>
        <p class="success-sub">Entraremos em contato o mais breve possível.</p>
      </div>
    </div>

    {!embed && (
      <a href="/" class="footer-link">nemeseteibel.adv.br</a>
    )}
  </div>

  <script define:vars={{ formId: form.id, successMessage: form.success_message }}>
    const phoneInput = document.getElementById('phone');
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('btn-submit');
    const formError = document.getElementById('form-error');
    const formWrapper = document.getElementById('form-wrapper');
    const successWrapper = document.getElementById('success-wrapper');
    const successMsg = document.getElementById('success-msg');

    phoneInput.addEventListener('input', () => {
      let v = phoneInput.value.replace(/\D/g, '').slice(0, 11);
      if (v.length === 0) { phoneInput.value = ''; return; }
      if (v.length <= 2) v = `(${v}`;
      else if (v.length <= 6) v = `(${v.slice(0,2)}) ${v.slice(2)}`;
      else if (v.length <= 10) v = `(${v.slice(0,2)}) ${v.slice(2,6)}-${v.slice(6)}`;
      else v = `(${v.slice(0,2)}) ${v.slice(2,7)}-${v.slice(7)}`;
      phoneInput.value = v;
    });

    function setErr(id, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = msg;
      const input = el.previousElementSibling;
      if (input && input.tagName === 'INPUT') {
        if (msg) input.classList.add('invalid');
        else input.classList.remove('invalid');
      }
    }

    function clearErrors() {
      ['err-name', 'err-email', 'err-phone', 'err-general'].forEach(id => setErr(id, ''));
      formError.style.display = 'none';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const phone = document.getElementById('phone').value.trim();

      let valid = true;

      if (!name || name.length < 2) {
        setErr('err-name', 'Nome é obrigatório (mínimo 2 caracteres).');
        valid = false;
      }

      if (!email && !phone) {
        setErr('err-general', 'Informe pelo menos e-mail ou WhatsApp.');
        valid = false;
      }

      if (email) {
        const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRe.test(email)) {
          setErr('err-email', 'E-mail inválido.');
          valid = false;
        }
      }

      if (phone) {
        const digits = phone.replace(/\D/g, '');
        if (digits.length < 10) {
          setErr('err-phone', 'WhatsApp inválido (mínimo 10 dígitos).');
          valid = false;
        }
      }

      if (!valid) return;

      btn.disabled = true;
      btn.textContent = 'Enviando…';

      try {
        const res = await fetch(`/api/forms/${formId}/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email: email || undefined, phone: phone || undefined }),
        });

        const data = await res.json();

        if (!res.ok) {
          formError.textContent = data.error ?? 'Erro ao enviar. Tente novamente.';
          formError.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Enviar mensagem';
          return;
        }

        successMsg.textContent = successMessage;
        formWrapper.style.display = 'none';
        successWrapper.style.display = 'block';
      } catch {
        formError.textContent = 'Erro de conexão. Verifique sua internet e tente novamente.';
        formError.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Enviar mensagem';
      }
    });
  </script>
</body>
</html>
